{
  "name": "Nodex",
  "version": "1.0.0",
  "description": "Control YouTube hands-free with head gestures. Face tracking runs entirely on your device — no video leaves the browser.",
  "manifest_version": 3,

  "permissions": [
    "storage",
    "sidePanel",
    "scripting",
    "webNavigation",
    "tabs"
  ],

  "host_permissions": [
    "https://www.youtube.com/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/mediapipe-bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],

  "side_panel": {
    "default_path": "sidepanel/index.html"
  },

  "action": {
    "default_title": "Open Nodex",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": [
        "assets/mediapipe/*",
        "content/mediapipe-bridge.js"
      ],
      "matches": ["https://www.youtube.com/*"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },

  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}